    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "^0.74.0",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "^2.16.1",
    "react-native-reanimated": "^3.10.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "^4.26.0",
